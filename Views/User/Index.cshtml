@model IEnumerable<AleksandarIvanov_NexaCore.Models.User>
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@ViewData["Title"]</h1>
    @* flex container that won’t wrap, with a small gap *@
    <div id="userControls" class="d-flex align-items-center flex-nowrap gap-2">
        @if (User.HasClaim("IsAdmin","True"))
        {
            <button type="button"
                    class="btn btn-success btn-sm"
                    data-bs-toggle="modal"
                    data-bs-target="#createUserModal">
                <i class="bi bi-person-plus-fill me-1"></i> New User
            </button>
        }
        <div id="searchUser"></div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="table-responsive">
        <table id="usersTable" class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>User Name</th>
                    <th>Email</th>
                    <th>Address</th>
                    <th>Is Admin?</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.Id</td>
                        <td>@u.UserName</td>
                        <td>@u.Email</td>
                        <td>@u.Address</td>
                        <td>@(u.IsAdmin ? "Yes" : "No")</td>
                        <td class="text-end">
                            <a asp-action="Details"
                               asp-route-id="@u.Id"
                               class="btn btn-outline-info btn-sm me-1"
                               title="View Details"
                               data-bs-toggle="tooltip">
                                <i class="bi bi-eye-fill"></i>
                            </a>

                            @if (User.HasClaim("IsAdmin", "True"))
                            {
                                <button type="button"
                                        class="btn btn-outline-primary btn-sm me-1"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editUserModal-@u.Id"
                                        title="Edit User"
                                        data-bs-toggle="tooltip">
                                    <i class="bi bi-pencil-fill"></i>
                                </button>
                                <a asp-action="Delete"
                                   asp-route-id="@u.Id"
                                   class="btn btn-outline-danger btn-sm"
                                   title="Delete User"
                                   data-bs-toggle="tooltip">
                                    <i class="bi bi-trash-fill"></i>
                                </a>
                            }
                        </td>
                    </tr>

                    @* --- Edit Modal --- *@
                    <div class="modal fade" id="editUserModal-@u.Id" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-lg">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Edit @u.UserName</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    @{
                                        ViewData["FormAction"] = "Edit";
                                    }
                                    @await Html.PartialAsync("_UserFormPartial", u)
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </tbody>
        </table>
    </div>
</div>

@* --- Create Modal --- *@
<div class="modal fade" id="createUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">New User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                @{
                    ViewData["FormAction"] = "Create";
                    var emptyUser = new AleksandarIvanov_NexaCore.Models.User
            {
                UserName = "",
                Email = "",
                Address = ""
            };
                }
                @await Html.PartialAsync("_UserFormPartial", emptyUser)
            </div>
        </div>
    </div>
</div>

@* --- Toast Message (bottom‑center) --- *@
@if (TempData["ToastMessage"] != null)
{
    <div class="position-fixed bottom-0 start-50 translate-middle-x p-3" style="z-index: 1200;">
        <div id="userToast"
             class="toast align-items-center text-white bg-success border-0"
             role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    @TempData["ToastMessage"]
                </div>
                <button type="button"
                        class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast"
                        aria-label="Close"></button>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        $(function(){
            // DataTable init
            var table = $('#usersTable').DataTable({
                paging: true,
                lengthChange: false,
                searching: true,
                ordering: true,
                info: false,
                autoWidth: false,
                initComplete: function() {
                    // Move the default search input into our placeholder
                    $('#usersTable_filter')
                      .appendTo('#searchUser')
                      .find('input')
                        .removeClass('form-control-sm')
                        .addClass('form-control form-control-sm')
                        .attr('placeholder','Search Users…');
                    // Remove the "Search:" label text
                    $('#searchUser label').contents()
                      .filter(n => n.nodeType === 3)
                      .remove();
                }
            });

            // Initialize tooltips
            function initTooltips() {
                document.querySelectorAll('[data-bs-toggle="tooltip"]')
                    .forEach(el => bootstrap.Tooltip.getOrCreateInstance(el));
            }
            initTooltips();
            table.on('draw', initTooltips);

            
        });
    </script>
}
