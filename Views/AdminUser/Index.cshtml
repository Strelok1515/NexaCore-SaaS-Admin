@model IEnumerable<AleksandarIvanov_NexaCore.Models.AdminUser>

@{
    ViewData["Title"] = "Admin Users";
}

<h1>@ViewData["Title"]</h1>

<table class="table table-striped table-bordered">
    <thead class="table-light">
        <tr>
            <th>AdminUser ID</th>
            <th>User Name</th>
            <th>Role</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var admin in Model)
        {
            <tr>
                <td>@admin.AdminUserId</td>
                <td>@admin.User.UserName</td>
                <td>@admin.Role</td>
                <td>
                    <a asp-action="Details"
                       asp-route-id="@admin.AdminUserId"
                       class="btn btn-info btn-sm">
                        Details
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
