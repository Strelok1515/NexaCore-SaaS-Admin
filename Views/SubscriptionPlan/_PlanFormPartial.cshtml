@model AleksandarIvanov_NexaCore.Models.SubscriptionPlan

<form asp-action="@ViewData["FormAction"]" method="post">
    @* If we're editing, the controller needs the id route *@
    @if ((string)ViewData["FormAction"] == "Edit")
    {
          <input type="hidden" asp-for="PlanId" />
    }

  <div class="row g-3">
    <div class="col-md-6">
      <div class="form-floating">
        <input asp-for="PlanName" class="form-control" placeholder="Plan name" />
        <label asp-for="PlanName">Plan Name</label>
        <span asp-validation-for="PlanName" class="text-danger small"></span>
      </div>
    </div>
    <div class="col-md-3">
      <div class="form-floating">
        <input asp-for="Price" class="form-control" placeholder="Price" />
        <label asp-for="Price">Price (AUD)</label>
        <span asp-validation-for="Price" class="text-danger small"></span>
      </div>
    </div>
    <div class="col-md-3">
      <div class="form-floating">
        <input asp-for="Duration" class="form-control" placeholder="Duration" />
        <label asp-for="Duration">Duration (days)</label>
        <span asp-validation-for="Duration" class="text-danger small"></span>
      </div>
    </div>
    <div class="col-12">
      <div class="form-floating">
        <textarea asp-for="Features" class="form-control" placeholder="Features" style="height:100px"></textarea>
        <label asp-for="Features">Features</label>
        <span asp-validation-for="Features" class="text-danger small"></span>
      </div>
    </div>
  </div>

  <div class="mt-4 text-end">
    <button type="submit" class="btn btn-primary px-4">Save</button>
    <button type="button" class="btn btn-secondary ms-2" data-bs-dismiss="modal">Cancel</button>
  </div>
</form>
