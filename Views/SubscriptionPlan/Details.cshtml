@model AleksandarIvanov_NexaCore.Models.SubscriptionPlan

@{
    ViewData["Title"] = "Plan Details";
}

<h1>@ViewData["Title"]</h1>

<div class="card mb-3">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Plan Name</dt>
            <dd class="col-sm-9">@Model.PlanName</dd>

            <dt class="col-sm-3">Price</dt>
            <dd class="col-sm-9">@Model.Price.ToString("C")</dd>

            <dt class="col-sm-3">Duration (days)</dt>
            <dd class="col-sm-9">@Model.Duration</dd>

            <dt class="col-sm-3">Features</dt>
            <dd class="col-sm-9">@Model.Features</dd>
        </dl>
        <a asp-action="Edit" asp-route-id="@Model.PlanId" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>
