@model AleksandarIvanov_NexaCore.Models.Customer
@using Microsoft.AspNetCore.Mvc.Rendering
@inject AleksandarIvanov_NexaCore.Data.ApplicationDbContext _dbContext

@{
    // Expect ViewData["FormAction"] = "Create" or "Edit"
    var action = (string)ViewData["FormAction"]!;
    // Build a user dropdown: (Id, UserName)
    var users = _dbContext.Users
        .Select(u => new SelectListItem(u.UserName, u.Id.ToString()))
        .ToList();
}

<form asp-action="@action" method="post">
    @if (action == "Edit")
    {
        <input type="hidden" asp-for="Id" />
    }

    <div class="mb-3">
        <label asp-for="Id" class="form-label">User</label>
        <select asp-for="Id" class="form-select"
                asp-items="users">
            <option value="">— Select user —</option>
        </select>
        <span asp-validation-for="Id" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label">Is Active?</label>
    </div>

    <div class="text-end">
        <button type="submit" class="btn btn-primary">Save</button>
        <button type="button" class="btn btn-secondary ms-2" data-bs-dismiss="modal">Cancel</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
