@model AleksandarIvanov_NexaCore.Models.Customer
@{
    ViewData["Title"] = "Create Customer";
}

<h1>@ViewData["Title"]</h1>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Id" class="form-label">User</label>
        <select asp-for="Id"
                class="form-select"
                asp-items="ViewBag.UserList">
        </select>
        <span asp-validation-for="Id" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label">Is Active?</label>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
