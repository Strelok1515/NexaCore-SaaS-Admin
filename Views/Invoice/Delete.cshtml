@model AleksandarIvanov_NexaCore.Models.Invoice

@{
    ViewData["Title"] = "Delete Invoice";
}

<h1>@ViewData["Title"]</h1>

<h3>Are you sure you want to delete this invoice?</h3>

<div class="card mb-3">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Invoice ID</dt>
            <dd class="col-sm-9">@Model.InvoiceId</dd>

            <dt class="col-sm-3">Subscription</dt>
            <dd class="col-sm-9">@Model.Subscription.SubscriptionId</dd>

            <dt class="col-sm-3">Customer</dt>
            <dd class="col-sm-9">@Model.Subscription.Customer.User.UserName</dd>

            <dt class="col-sm-3">Amount</dt>
            <dd class="col-sm-9">@Model.Amount.ToString("C")</dd>

            <dt class="col-sm-3">Due Date</dt>
            <dd class="col-sm-9">@Model.DueDate.ToShortDateString()</dd>

            <dt class="col-sm-3">Payment Status</dt>
            <dd class="col-sm-9">@Model.PaymentStatus</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="InvoiceId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
