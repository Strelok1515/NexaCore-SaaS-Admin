@model AleksandarIvanov_NexaCore.Models.Subscription
@using Microsoft.AspNetCore.Mvc.Rendering
@inject AleksandarIvanov_NexaCore.Data.ApplicationDbContext _db
@using Microsoft.EntityFrameworkCore

@{
    var action = (string)ViewData["FormAction"]!;
    // build dropdown lists
    var customers = _db.Customers
        .Include(c => c.User)
        .Select(c => new SelectListItem
                {
                    Text = c.User.UserName,
                    Value = c.Id.ToString()
                }).ToList();

    var plans = _db.SubscriptionPlans
        .Select(p => new SelectListItem
                {
                    Text = p.PlanName,
                    Value = p.PlanId.ToString()
                }).ToList();
}

<form asp-action="@action" method="post">
    @if (action == "Edit")
    {
        <input type="hidden" asp-for="SubscriptionId" />
    }

    <div class="mb-3">
        <label asp-for="CustomerId" class="form-label">Customer</label>
        <select asp-for="CustomerId"
                class="form-select"
                asp-items="customers">
            <option value="">— Select customer —</option>
        </select>
        <span asp-validation-for="CustomerId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PlanId" class="form-label">Plan</label>
        <select asp-for="PlanId"
                class="form-select"
                asp-items="plans">
            <option value="">— Select plan —</option>
        </select>
        <span asp-validation-for="PlanId" class="text-danger"></span>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-6">
            <label asp-for="StartDate" class="form-label">Start Date</label>
            <input asp-for="StartDate" type="date" class="form-control" />
            <span asp-validation-for="StartDate" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="EndDate" class="form-label">End Date</label>
            <input asp-for="EndDate" type="date" class="form-control" />
            <span asp-validation-for="EndDate" class="text-danger"></span>
        </div>
    </div>

    <div class="text-end">
        <button type="submit" class="btn btn-primary">Save</button>
        <button type="button" class="btn btn-secondary ms-2" data-bs-dismiss="modal">Cancel</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
